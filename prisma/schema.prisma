generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum LocaleCode {
  EN
  FR
  ES
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum OpportunityStatus {
  DRAFT
  IDENTIFIED
  ASSESSING
  PRIORITIZED
  APPROVED
  IN_PROGRESS
  LIVE
  BLOCKED
  ARCHIVED
  // New statuses for the simplified intake workflow
  VALIDATED
  CONVERTED
  REJECTED
}

enum OpportunityBadge {
  NONE
  QUICK_WIN
  STRATEGIC
  TRANSFORMATIONAL
  HIGH_CONFIDENCE
  AT_RISK
}

enum DecisionStatus {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
  NEEDS_INFO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum MetricType {
  FINANCIAL
  EFFICIENCY
  QUALITY
  RISK
  ADOPTION
  TIME
  CUSTOMER
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceStatus {
  NOT_STARTED
  IN_REVIEW
  PASSED
  FAILED
  WAIVED
}

enum UsageEventType {
  AI_REQUEST
  PROCESS_CREATED
  OPPORTUNITY_CREATED
  USER_INVITED
  EXPORT_TRIGGERED
  GOVERNANCE_REVIEW
  API_CALL
  LOGIN
}

enum FeatureKey {
  CUSTOM_SCORING
  ADVANCED_WORKFLOWS
  ADVANCED_EXPORTS
  PORTFOLIO_GOVERNANCE
  ADVANCED_GOVERNANCE
  MULTI_BUSINESS_UNIT
  SSO
  SCIM
  FULL_AUDIT
  API_ACCESS
  CENTRALIZED_ADMIN
}

enum LimitKey {
  WORKSPACES
  USERS
  PROCESSES
  OPPORTUNITIES
  AI_REQUESTS_PER_MONTH
  BUSINESS_UNITS
}

enum LimitScope {
  TENANT
  WORKSPACE
}

enum LimitPeriod {
  TOTAL
  MONTHLY
}

enum DataReadinessLevel {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  PRODUCTION_READY
}

enum AssessmentType {
  INITIAL
  REVIEW
  REASSESSMENT
  GOVERNANCE
  EXECUTION
}

enum DependencyType {
  OPPORTUNITY
  INITIATIVE
  APPLICATION
  DATA_SOURCE
  EXTERNAL
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum InitiativeStatus {
  PLANNED
  IN_PROGRESS
  AT_RISK
  COMPLETED
  CANCELED
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  DONE
  MISSED
}

enum AttachmentKind {
  DOCUMENT
  IMAGE
  LINK
  EXPORT
  OTHER
}

enum AuditActorType {
  USER
  SYSTEM
  API
}

// Core tenancy and billing.
// Seed FREE / PRO / ENTERPRISE in SubscriptionPlan, then attach features and limits.
// FREE should typically include:
// - 1 workspace
// - 5 users
// - 15 processes
// - 30 opportunities
// - 30 AI requests per month
// - no custom scoring, advanced workflows, multi-BU, SSO, SCIM, or full audit
model SubscriptionPlan {
  id           String   @id @default(cuid())
  planType     PlanType @unique
  name         String
  description  String?  @db.Text
  isPublic     Boolean  @default(true)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants  Tenant[]
  features PlanFeature[]
  limits   PlanLimit[]
}

model PlanFeature {
  id          String     @id @default(cuid())
  planId      String
  featureKey  FeatureKey
  label       String
  description String?    @db.Text
  enabled     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model PlanLimit {
  id          String      @id @default(cuid())
  planId      String
  limitKey    LimitKey
  scope       LimitScope  @default(WORKSPACE)
  period      LimitPeriod @default(TOTAL)
  limitValue  Int?
  description String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  usageQuotas UsageQuota[]

  @@unique([planId, limitKey, scope, period])
  @@index([limitKey, scope, period])
}

model Tenant {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  subscriptionPlanId String
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  billingEmail       String?
  trialEndsAt        DateTime?
  planActivatedAt    DateTime?
  settings           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  workspaces       Workspace[]
  usageQuotas      UsageQuota[]
  usageEvents      UsageEvent[]
  auditLogs        AuditLog[]

  @@index([subscriptionPlanId, subscriptionStatus])
}

model Workspace {
  id            String          @id @default(cuid())
  tenantId      String
  name          String
  slug          String
  status        WorkspaceStatus @default(ACTIVE)
  defaultLocale LocaleCode      @default(EN)
  settings      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  planType             String   @default("FREE") // FREE|PRO|ENTERPRISE
  planExpiresAt        DateTime?
  seatsUsed            Int      @default(0)
  seatsLimit           Int      @default(2)

  // Onboarding / sector intelligence
  sectorCode           String?  // e.g. "finance", "retail", "healthcare"
  companySize          String?  // "tpe" | "pme" | "eti" | "ge"
  aiMaturity           String?  // "debutant" | "experimentateur" | "avance" | "leader"
  priorities           Json?    // string[] — selected strategic priorities
  horizon              String?  // "6_months" | "1_year" | "3_years"

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships      Membership[]
  certifications   WorkspaceCertification[]
  roles            Role[]
  businessUnits    BusinessUnit[]
  domains          Domain[]
  capabilities     Capability[]
  processes        Process[]
  subProcesses     SubProcess[]
  painPoints       PainPoint[]
  applications     Application[]
  dataSources      DataSource[]
  kpis             KPI[]
  tags             Tag[]
  opportunityTypes OpportunityType[]
  scoreTemplates   ScoreTemplate[]
  opportunities    Opportunity[]
  useCases         UseCase[]
  decisionBoards   DecisionBoard[]
  reviewMeetings   ReviewMeeting[]
  decisions        Decision[]
  actionItems      ActionItem[]
  initiatives      Initiative[]
  benefitMetrics   BenefitMetric[]
  adoptionMetrics  AdoptionMetric[]
  attachments      Attachment[]
  usageQuotas      UsageQuota[]
  usageEvents      UsageEvent[]
  auditLogs        AuditLog[]
  technologies     Technology[]
  aiAssessments    AIReadinessAssessment[]
  archDecisions    ArchitectureDecision[]
  // Sprint 4
  copilotConversations CopilotConversation[]
  scenarios            Scenario[]
  notifications        Notification[]
  webhooks             Webhook[]
  // Sprint 3
  ingestionJobs          IngestionJob[]
  relationshipSuggestions RelationshipSuggestion[]
  dataQualityReports     DataQualityReport[]
  surveys                Survey[]
  attestations           Attestation[]
  ariaSessions           AriaSession[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

// Optional business-unit layer used mainly by Enterprise customers.
model BusinessUnit {
  id               String    @id @default(cuid())
  workspaceId      String
  parentId         String?
  name             String
  slug             String
  code             String?
  description      String?   @db.Text
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent         BusinessUnit?   @relation("BusinessUnitHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       BusinessUnit[]  @relation("BusinessUnitHierarchy")
  domains        Domain[]
  capabilities   Capability[]
  processes      Process[]
  opportunities  Opportunity[]
  decisionBoards DecisionBoard[]
  initiatives    Initiative[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([parentId])
}

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String?    @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  status          UserStatus @default(ACTIVE)
  preferredLocale LocaleCode @default(EN)
  jobTitle        String?
  preferences     Json?
  lastLoginAt     DateTime?
  userFunction    String?    // transformation_manager | enterprise_architect
  isPlatformAdmin Boolean    @default(false)
  hasCompletedProcessFocusOnboarding Boolean @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  accounts               Account[]
  sessions               Session[]
  memberships            Membership[]
  ownedProcesses         Process[]               @relation("ProcessOwner")
  ownedOpportunities     Opportunity[]           @relation("OpportunityOwner")
  sponsoredOpportunities Opportunity[]           @relation("OpportunitySponsor")
  createdOpportunities   Opportunity[]           @relation("OpportunityCreator")
  assessments            OpportunityAssessment[] @relation("AssessmentAssessor")
  chairedBoards          DecisionBoard[]         @relation("DecisionBoardChair")
  decisionsMade          Decision[]              @relation("DecisionMaker")
  approvalAssignments    ApprovalStep[]          @relation("ApprovalApprover")
  ownedRiskItems         RiskItem[]              @relation("RiskOwner")
  ownedComplianceChecks  ComplianceCheck[]       @relation("ComplianceOwner")
  authoredComments       OpportunityComment[]    @relation("CommentAuthor")
  ownedActionItems       ActionItem[]            @relation("ActionItemOwner")
  ownedInitiatives       Initiative[]            @relation("InitiativeOwner")
    uploadedAttachments    Attachment[]            @relation("AttachmentUploader")
    auditLogs              AuditLog[]              @relation("AuditActor")
    usageEvents            UsageEvent[]
    processFocusSelections UserProcessFocusSelection[]
    diagramVersions        ProcessDiagramVersion[]
    ownedCapabilities      Capability[]            @relation("CapabilityOwner")
    businessOwnerApps      Application[]           @relation("AppBusinessOwner")
    itOwnerApps            Application[]           @relation("AppITOwner")
    architectureDecisions  ArchitectureDecision[]  @relation("ArchDecisionAuthor")
    guideProgress          UserGuideProgress?
    pageVisits             PageFirstVisit[]
    diagramComments        DiagramComment[]        @relation("DiagramCommentAuthor")
    diagramCommentReplies  DiagramCommentReply[]   @relation("DiagramReplyAuthor")
    diagramAssignments     DiagramTaskAssignment[] @relation("DiagramAssignee")
    diagramAssignedTasks   DiagramTaskAssignment[] @relation("DiagramAssigner")
    ownedCertifications    WorkspaceCertification[] @relation("CertificationOwner")
    ariaSessions           AriaSession[]
    ariaDismissals         AriaDismissal[]
    processesAssteward     Process[]      @relation("ProcessSteward")
    processHistories       ProcessHistory[]
  }

model Membership {
  id           String           @id @default(cuid())
  userId       String
  workspaceId  String
  roleId       String
  status       MembershipStatus @default(INVITED)
  acceptedAt   DateTime?
  lastActiveAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, workspaceId])
  @@index([workspaceId, status])
  @@index([roleId])
}

model Role {
  id          String    @id @default(cuid())
  workspaceId String
  code        String
  name        String
  description String?   @db.Text
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships Membership[]
  permissions RolePermission[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UsageQuota {
  id            String      @id @default(cuid())
  tenantId      String
  workspaceId   String?
  planLimitId   String?
  limitKey      LimitKey
  scope         LimitScope
  period        LimitPeriod
  periodStart   DateTime
  periodEnd     DateTime
  allowedValue  Int?
  consumedValue Int         @default(0)
  resetAt       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planLimit PlanLimit?   @relation(fields: [planLimitId], references: [id], onDelete: SetNull)
  events    UsageEvent[]

  @@index([tenantId, limitKey, periodStart])
  @@index([workspaceId, limitKey, periodStart])
}

model UsageEvent {
  id           String         @id @default(cuid())
  tenantId     String
  workspaceId  String?
  userId       String?
  usageQuotaId String?
  type         UsageEventType
  quantity     Int            @default(1)
  occurredAt   DateTime       @default(now())
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  usageQuota UsageQuota? @relation(fields: [usageQuotaId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, occurredAt])
  @@index([workspaceId, type, occurredAt])
}

model AuditLog {
  id          String         @id @default(cuid())
  tenantId    String
  workspaceId String?
  actorUserId String?
  actorType   AuditActorType @default(USER)
  action      String
  entityType  String
  entityId    String?
  summary     String?        @db.Text
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser User?      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, createdAt])
  @@index([workspaceId, createdAt])
}

// Lightweight business mapping.
model Domain {
  id               String    @id @default(cuid())
  workspaceId      String
  businessUnitId   String?
  name             String
  slug             String
  description      String?   @db.Text
  // Optional custom labels if customers later want localized names.
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit  BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  capabilities  Capability[]
  processes     Process[]
  painPoints    PainPoint[]
  opportunities Opportunity[]

  @@unique([workspaceId, slug])
  @@index([businessUnitId])
}

model Capability {
  id               String    @id @default(cuid())
  workspaceId      String
  businessUnitId   String?
  domainId         String
  name             String
  slug             String
  description      String?   @db.Text
  nameTranslations Json?
  level            Int       @default(0)
  parentId         String?
  ownerId          String?
  strategicValue   String?
  aiPotential      String?
  maturityScore    Float?
  // Sector catalog fields
  code             String?   // catalog reference code, unique within a workspace
  isFromCatalog    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit     BusinessUnit?      @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  domain           Domain             @relation(fields: [domainId], references: [id], onDelete: Cascade)
  parent           Capability?        @relation("CapabilityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children         Capability[]       @relation("CapabilityTree")
  owner            User?              @relation("CapabilityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  processes        Process[]
  painPoints       PainPoint[]
  opportunities    Opportunity[]
  appCapabilities  AppCapabilityMap[]

  @@unique([workspaceId, slug])
  @@unique([workspaceId, code])
  @@index([domainId])
  @@index([businessUnitId])
  @@index([parentId])
  @@index([ownerId])
}

model Process {
  id               String    @id @default(cuid())
  workspaceId      String
  businessUnitId   String?
  domainId         String
  capabilityId     String?
  ownerId          String?
  name             String
  slug             String
  description      String?   @db.Text
  nameTranslations Json?
  frequency        String?
  volumePerDay     Int?
  manualEffortH    Float?
  automationRate   Float?
  dataQuality      String?
  painLevel        Int?
  aiPotential      String?
  processStatus    String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace       Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit    BusinessUnit?              @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  domain          Domain                     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  capability      Capability?                @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  // Catalogue SAP/LeanIX
  catalogCode     String?   // ex: "HR-ADM-02"

  // Maturity CMMI
  maturityScore   Int?      @default(0)
  maturityLevel   String?   // initial|managed|defined|quantitatively_managed|optimizing

  // Gouvernance étendue
  stewardId       String?
  sla             String?
  scope           String?   @db.Text
  objective       String?   @db.Text
  tags            Json?
  docLinks        Json?
  isCertified     Boolean   @default(false)
  certificationRef String?

  // Métriques
  errorRate       Float?    // % d'erreurs
  cycleDays       Float?    // durée cycle en jours

  owner           User?                      @relation("ProcessOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  steward         User?                      @relation("ProcessSteward", fields: [stewardId], references: [id], onDelete: SetNull)
  subProcesses    SubProcess[]
  painPoints      PainPoint[]
  kpis            KPI[]
  opportunities   Opportunity[]
  applications    ProcessApplication[]
  dataSources     ProcessDataSource[]
  focusSelections UserProcessFocusSelection[]
  steps           ProcessStep[]
  diagram         ProcessDiagram?
  processKpis     ProcessKPI[]
  dependencies    ProcessDependency[]  @relation("DependencySource")
  dependents      ProcessDependency[]  @relation("DependencyTarget")
  history         ProcessHistory[]

  @@unique([workspaceId, slug])
  @@index([domainId])
  @@index([capabilityId])
  @@index([ownerId])
  @@index([catalogCode])
}

model UserProcessFocusSelection {
  userId    String
  processId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@id([userId, processId])
  @@index([processId])
}

model SubProcess {
  id               String    @id @default(cuid())
  workspaceId      String
  processId        String
  name             String
  slug             String
  description      String?   @db.Text
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  process       Process       @relation(fields: [processId], references: [id], onDelete: Cascade)
  painPoints    PainPoint[]
  opportunities Opportunity[]

  @@unique([workspaceId, slug])
  @@index([processId])
}

model PainPoint {
  id               String       @id @default(cuid())
  workspaceId      String
  domainId         String?
  capabilityId     String?
  processId        String?
  subProcessId     String?
  title            String
  description      String?      @db.Text
  nameTranslations Json?
  severity         RiskSeverity @default(MEDIUM)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain        Domain?       @relation(fields: [domainId], references: [id], onDelete: SetNull)
  capability    Capability?   @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  process       Process?      @relation(fields: [processId], references: [id], onDelete: SetNull)
  subProcess    SubProcess?   @relation(fields: [subProcessId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]

  @@index([processId])
  @@index([subProcessId])
  @@index([capabilityId])
}

model Application {
  id                  String    @id @default(cuid())
  workspaceId         String
  name                String
  slug                String
  vendor              String?
  description         String?   @db.Text
  nameTranslations    Json?
  lifecycleState      String    @default("active")
  criticality         String?
  deploymentType      String?
  url                 String?
  documentationUrl    String?
  annualCost          Float?
  userCount           Int?
  aiReadinessScore    Float?
  qualityScore        Float?
  businessOwnerId     String?
  itOwnerId           String?
  modernizationAdvice Json?
  appTags             Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessOwner  User?                    @relation("AppBusinessOwner", fields: [businessOwnerId], references: [id], onDelete: SetNull)
  itOwner        User?                    @relation("AppITOwner", fields: [itOwnerId], references: [id], onDelete: SetNull)
  processes      ProcessApplication[]
  dataSources    ApplicationDataSource[]
  opportunities  OpportunityApplication[]
  capabilities   AppCapabilityMap[]
  technologies   AppTechnologyMap[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([businessOwnerId])
  @@index([itOwnerId])
}

model DataSource {
  id               String    @id @default(cuid())
  workspaceId      String
  name             String
  slug             String
  systemName       String?
  classification   String?
  description      String?   @db.Text
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  applications  ApplicationDataSource[]
  processes     ProcessDataSource[]
  opportunities OpportunityDataSource[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model KPI {
  id               String     @id @default(cuid())
  workspaceId      String
  processId        String?
  name             String
  slug             String
  unit             String?
  description      String?    @db.Text
  metricType       MetricType
  nameTranslations Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  process        Process?         @relation(fields: [processId], references: [id], onDelete: SetNull)
  opportunities  OpportunityKPI[]
  benefitMetrics BenefitMetric[]

  @@unique([workspaceId, slug])
  @@index([processId])
}

model Tag {
  id               String    @id @default(cuid())
  workspaceId      String
  name             String
  slug             String
  color            String?
  description      String?   @db.Text
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities OpportunityTag[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

// Opportunity portfolio and scoring.
model OpportunityType {
  id               String    @id @default(cuid())
  workspaceId      String
  code             String
  name             String
  description      String?   @db.Text
  isSystem         Boolean   @default(false)
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model ScoreTemplate {
  id               String    @id @default(cuid())
  workspaceId      String
  code             String
  name             String
  description      String?   @db.Text
  isDefault        Boolean   @default(false)
  isSystem         Boolean   @default(false)
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dimensions    ScoreDimension[]
  opportunities Opportunity[]
  assessments   OpportunityAssessment[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model ScoreDimension {
  id              String      @id @default(cuid())
  scoreTemplateId String
  key             String
  name            String
  description     String?     @db.Text
  metricType      MetricType?
  weight          Decimal     @default(0) @db.Decimal(5, 2)
  displayOrder    Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  scoreTemplate ScoreTemplate @relation(fields: [scoreTemplateId], references: [id], onDelete: Cascade)
  scoreResults  ScoreResult[]

  @@unique([scoreTemplateId, key])
  @@index([scoreTemplateId, displayOrder])
}

/// Central entity: a scored AI opportunity attached to business context.
model Opportunity {
  id                  String             @id @default(cuid())
  workspaceId         String
  businessUnitId      String?
  domainId            String
  capabilityId        String
  processId           String
  subProcessId        String?
  painPointId         String?
  ownerId             String?
  sponsorId           String?
  createdById         String?
  opportunityTypeId   String
  scoreTemplateId     String?
  currentDecisionId   String?            @unique
  title               String
  titleTranslations   Json?
  summary             String?            @db.Text
  summaryTranslations Json?
  problemStatement    String?            @db.Text
  aiHypothesis        String?            @db.Text
  status              OpportunityStatus  @default(DRAFT)
  badge               OpportunityBadge   @default(NONE)
  dataReadiness       DataReadinessLevel @default(UNKNOWN)
  riskSeverity        RiskSeverity       @default(MEDIUM)
  expectedValue       Decimal?           @db.Decimal(18, 2)
  realizedValue       Decimal?           @db.Decimal(18, 2)
  overallScore        Decimal?           @db.Decimal(6, 2)
  currencyCode        String             @default("USD") @db.VarChar(3)
  // ── Intake / quick-capture fields (added for simplified workflow) ──
  detectedBy          String             @default("manual") // "ai" | "manual" | "terrain"
  sourceText          String?            @db.Text           // raw natural-language input
  gainEstimate        String?            @db.VarChar(255)   // e.g. "-40% processing time"
  complexity          String             @default("medium") // "low" | "medium" | "high"
  priorityLevel       String             @default("P2")     // "P0" | "P1" | "P2"
  domainLabel         String?            @db.VarChar(80)    // simple label when no Domain FK
  rejectionReason     String?            @db.Text
  useCaseId           String?            @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  workspace        Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit     BusinessUnit?            @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  domain           Domain                   @relation(fields: [domainId], references: [id], onDelete: Restrict)
  capability       Capability               @relation(fields: [capabilityId], references: [id], onDelete: Restrict)
  process          Process                  @relation(fields: [processId], references: [id], onDelete: Restrict)
  subProcess       SubProcess?              @relation(fields: [subProcessId], references: [id], onDelete: SetNull)
  painPoint        PainPoint?               @relation(fields: [painPointId], references: [id], onDelete: SetNull)
  owner            User?                    @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  sponsor          User?                    @relation("OpportunitySponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  createdBy        User?                    @relation("OpportunityCreator", fields: [createdById], references: [id], onDelete: SetNull)
  opportunityType  OpportunityType          @relation(fields: [opportunityTypeId], references: [id], onDelete: Restrict)
  scoreTemplate    ScoreTemplate?           @relation(fields: [scoreTemplateId], references: [id], onDelete: SetNull)
  currentDecision  Decision?                @relation("CurrentOpportunityDecision", fields: [currentDecisionId], references: [id], onDelete: SetNull)
  assessments      OpportunityAssessment[]
  applications     OpportunityApplication[]
  dataSources      OpportunityDataSource[]
  kpis             OpportunityKPI[]
  tags             OpportunityTag[]
  dependencies     Dependency[]             @relation("OpportunityDependencies")
  blockedBy        Dependency[]             @relation("OpportunityDependencyTargets")
  risks            RiskItem[]
  complianceChecks ComplianceCheck[]
  comments         OpportunityComment[]
  decisions        Decision[]               @relation("OpportunityDecisions")
  actionItems      ActionItem[]
  initiatives      Initiative[]
  benefitMetrics   BenefitMetric[]
  adoptionMetrics  AdoptionMetric[]
  attachments      Attachment[]
  useCase          UseCase?                 @relation("OpportunityUseCase")

  @@index([workspaceId, status])
  @@index([processId, status])
  @@index([ownerId])
  @@index([sponsorId])
  @@index([opportunityTypeId])
  @@index([businessUnitId])
}

model OpportunityAssessment {
  id               String         @id @default(cuid())
  opportunityId    String
  scoreTemplateId  String
  assessorId       String?
  assessmentType   AssessmentType @default(INITIAL)
  summary          String?        @db.Text
  notes            String?        @db.Text
  recommendation   String?        @db.Text
  valueScore       Decimal?       @db.Decimal(6, 2)
  feasibilityScore Decimal?       @db.Decimal(6, 2)
  confidenceScore  Decimal?       @db.Decimal(6, 2)
  riskScore        Decimal?       @db.Decimal(6, 2)
  overallScore     Decimal?       @db.Decimal(6, 2)
  isCurrent        Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  opportunity     Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  scoreTemplate   ScoreTemplate @relation(fields: [scoreTemplateId], references: [id], onDelete: Restrict)
  assessor        User?         @relation("AssessmentAssessor", fields: [assessorId], references: [id], onDelete: SetNull)
  dimensionScores ScoreResult[]

  @@index([opportunityId, createdAt])
  @@index([assessorId])
  @@index([scoreTemplateId])
}

model ScoreResult {
  id                      String   @id @default(cuid())
  opportunityAssessmentId String
  scoreDimensionId        String
  rawValue                Decimal  @db.Decimal(10, 4)
  normalizedValue         Decimal? @db.Decimal(10, 4)
  weightedValue           Decimal? @db.Decimal(10, 4)
  notes                   String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  opportunityAssessment OpportunityAssessment @relation(fields: [opportunityAssessmentId], references: [id], onDelete: Cascade)
  scoreDimension        ScoreDimension        @relation(fields: [scoreDimensionId], references: [id], onDelete: Restrict)

  @@unique([opportunityAssessmentId, scoreDimensionId])
  @@index([scoreDimensionId])
}

model Dependency {
  id                  String         @id @default(cuid())
  opportunityId       String
  targetOpportunityId String?
  targetInitiativeId  String?
  dependencyType      DependencyType
  title               String?
  description         String?        @db.Text
  isBlocking          Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  opportunity       Opportunity  @relation("OpportunityDependencies", fields: [opportunityId], references: [id], onDelete: Cascade)
  targetOpportunity Opportunity? @relation("OpportunityDependencyTargets", fields: [targetOpportunityId], references: [id], onDelete: SetNull)
  targetInitiative  Initiative?  @relation("InitiativeDependencyTargets", fields: [targetInitiativeId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([targetOpportunityId])
  @@index([targetInitiativeId])
}

model RiskItem {
  id             String       @id @default(cuid())
  opportunityId  String
  ownerId        String?
  title          String
  description    String?      @db.Text
  severity       RiskSeverity @default(MEDIUM)
  status         RiskStatus   @default(OPEN)
  mitigationPlan String?      @db.Text
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  owner       User?       @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([opportunityId, status])
  @@index([ownerId])
}

model ComplianceCheck {
  id            String           @id @default(cuid())
  opportunityId String
  ownerId       String?
  framework     String
  controlName   String
  requirement   String?          @db.Text
  status        ComplianceStatus @default(NOT_STARTED)
  notes         String?          @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  owner       User?       @relation("ComplianceOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([opportunityId, status])
  @@index([ownerId])
}

model OpportunityComment {
  id            String    @id @default(cuid())
  opportunityId String
  authorId      String
  body          String    @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  author      User        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([opportunityId, createdAt])
  @@index([authorId])
}

model Attachment {
  id              String         @id @default(cuid())
  workspaceId     String
  opportunityId   String?
  initiativeId    String?
  decisionId      String?
  reviewMeetingId String?
  uploadedById    String?
  kind            AttachmentKind @default(DOCUMENT)
  fileName        String
  storageKey      String?
  mimeType        String?
  sizeBytes       Int?
  externalUrl     String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  initiative    Initiative?    @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  decision      Decision?      @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  reviewMeeting ReviewMeeting? @relation(fields: [reviewMeetingId], references: [id], onDelete: SetNull)
  uploadedBy    User?          @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, kind])
  @@index([opportunityId])
  @@index([initiativeId])
  @@index([decisionId])
  @@index([reviewMeetingId])
}

// Explicit joins keep the process and portfolio graph queryable and easy to extend.
model OpportunityApplication {
  opportunityId String
  applicationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([opportunityId, applicationId])
  @@index([applicationId])
}

model OpportunityDataSource {
  opportunityId String
  dataSourceId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  dataSource  DataSource  @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@id([opportunityId, dataSourceId])
  @@index([dataSourceId])
}

model OpportunityKPI {
  opportunityId String
  kpiId         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  kpi         KPI         @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@id([opportunityId, kpiId])
  @@index([kpiId])
}

model OpportunityTag {
  opportunityId String
  tagId         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([opportunityId, tagId])
  @@index([tagId])
}

model ProcessApplication {
  processId     String
  applicationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  process     Process     @relation(fields: [processId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([processId, applicationId])
  @@index([applicationId])
}

model ProcessDataSource {
  processId    String
  dataSourceId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  process    Process    @relation(fields: [processId], references: [id], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@id([processId, dataSourceId])
  @@index([dataSourceId])
}

model ApplicationDataSource {
  applicationId String
  dataSourceId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  dataSource  DataSource  @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@id([applicationId, dataSourceId])
  @@index([dataSourceId])
}

// Governance keeps prioritization and approval separate from execution.
model DecisionBoard {
  id               String    @id @default(cuid())
  workspaceId      String
  businessUnitId   String?
  chairId          String?
  name             String
  slug             String
  description      String?   @db.Text
  nameTranslations Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit   BusinessUnit?   @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  chair          User?           @relation("DecisionBoardChair", fields: [chairId], references: [id], onDelete: SetNull)
  reviewMeetings ReviewMeeting[]
  decisions      Decision[]

  @@unique([workspaceId, slug])
  @@index([businessUnitId])
  @@index([chairId])
}

model ReviewMeeting {
  id              String        @id @default(cuid())
  workspaceId     String
  decisionBoardId String
  title           String
  scheduledAt     DateTime
  heldAt          DateTime?
  status          MeetingStatus @default(SCHEDULED)
  summary         String?       @db.Text
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  decisionBoard DecisionBoard @relation(fields: [decisionBoardId], references: [id], onDelete: Cascade)
  decisions     Decision[]
  actionItems   ActionItem[]
  attachments   Attachment[]

  @@index([workspaceId, scheduledAt])
  @@index([decisionBoardId, status])
}

model Decision {
  id              String         @id @default(cuid())
  workspaceId     String
  opportunityId   String
  decisionBoardId String?
  reviewMeetingId String?
  decidedById     String?
  status          DecisionStatus @default(PENDING)
  summary         String?        @db.Text
  rationale       String?        @db.Text
  approvedBudget  Decimal?       @db.Decimal(18, 2)
  currencyCode    String?        @db.VarChar(3)
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity           Opportunity    @relation("OpportunityDecisions", fields: [opportunityId], references: [id], onDelete: Cascade)
  currentForOpportunity Opportunity?   @relation("CurrentOpportunityDecision")
  decisionBoard         DecisionBoard? @relation(fields: [decisionBoardId], references: [id], onDelete: SetNull)
  reviewMeeting         ReviewMeeting? @relation(fields: [reviewMeetingId], references: [id], onDelete: SetNull)
  decidedBy             User?          @relation("DecisionMaker", fields: [decidedById], references: [id], onDelete: SetNull)
  approvalSteps         ApprovalStep[]
  actionItems           ActionItem[]
  initiatives           Initiative[]
  attachments           Attachment[]

  @@index([workspaceId, status])
  @@index([opportunityId, decidedAt])
  @@index([decisionBoardId])
  @@index([reviewMeetingId])
  @@index([decidedById])
}

model ApprovalStep {
  id                String         @id @default(cuid())
  decisionId        String
  approverId        String?
  stepOrder         Int
  approverRoleLabel String?
  status            ApprovalStatus @default(PENDING)
  notes             String?        @db.Text
  dueDate           DateTime?
  actedAt           DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  approver User?    @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@unique([decisionId, stepOrder])
  @@index([approverId, status])
}

model ActionItem {
  id              String           @id @default(cuid())
  workspaceId     String
  opportunityId   String?
  decisionId      String?
  reviewMeetingId String?
  ownerId         String?
  title           String
  description     String?          @db.Text
  status          ActionItemStatus @default(OPEN)
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  decision      Decision?      @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  reviewMeeting ReviewMeeting? @relation(fields: [reviewMeetingId], references: [id], onDelete: SetNull)
  owner         User?          @relation("ActionItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([ownerId, status])
  @@index([opportunityId])
}

// Execution and value tracking.
model Initiative {
  id             String           @id @default(cuid())
  workspaceId    String
  businessUnitId String?
  opportunityId  String?
  decisionId     String?
  ownerId        String?
  name           String
  slug           String
  description    String?          @db.Text
  status         InitiativeStatus @default(PLANNED)
  budgetAmount   Decimal?         @db.Decimal(18, 2)
  currencyCode   String?          @db.VarChar(3)
  startDate      DateTime?
  targetDate     DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  workspace            Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessUnit         BusinessUnit?    @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  opportunity          Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  decision             Decision?        @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  owner                User?            @relation("InitiativeOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  milestones           Milestone[]
  benefitMetrics       BenefitMetric[]
  adoptionMetrics      AdoptionMetric[]
  blockingDependencies Dependency[]     @relation("InitiativeDependencyTargets")
  attachments          Attachment[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([opportunityId])
  @@index([decisionId])
  @@index([businessUnitId])
  @@index([ownerId])
}

model Milestone {
  id           String          @id @default(cuid())
  initiativeId String
  name         String
  description  String?         @db.Text
  status       MilestoneStatus @default(PLANNED)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId, status])
}

model BenefitMetric {
  id            String     @id @default(cuid())
  workspaceId   String
  opportunityId String?
  initiativeId  String?
  kpiId         String?
  name          String
  description   String?    @db.Text
  metricType    MetricType
  unit          String?
  targetValue   Decimal?   @db.Decimal(18, 4)
  currentValue  Decimal?   @db.Decimal(18, 4)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  initiative     Initiative?     @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  kpi            KPI?            @relation(fields: [kpiId], references: [id], onDelete: SetNull)
  baselineValues BaselineValue[]
  realizedValues RealizedValue[]

  @@index([workspaceId, metricType])
  @@index([opportunityId])
  @@index([initiativeId])
  @@index([kpiId])
}

model BaselineValue {
  id              String   @id @default(cuid())
  benefitMetricId String
  value           Decimal  @db.Decimal(18, 4)
  capturedAt      DateTime
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  benefitMetric BenefitMetric @relation(fields: [benefitMetricId], references: [id], onDelete: Cascade)

  @@index([benefitMetricId, capturedAt])
}

model RealizedValue {
  id              String   @id @default(cuid())
  benefitMetricId String
  value           Decimal  @db.Decimal(18, 4)
  capturedAt      DateTime
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  benefitMetric BenefitMetric @relation(fields: [benefitMetricId], references: [id], onDelete: Cascade)

  @@index([benefitMetricId, capturedAt])
}

model AdoptionMetric {
  id            String     @id @default(cuid())
  workspaceId   String
  opportunityId String?
  initiativeId  String?
  name          String
  description   String?    @db.Text
  unit          String?
  metricType    MetricType @default(ADOPTION)
  baselineValue Decimal?   @db.Decimal(18, 4)
  targetValue   Decimal?   @db.Decimal(18, 4)
  currentValue  Decimal?   @db.Decimal(18, 4)
  capturedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  initiative  Initiative?  @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, metricType])
  @@index([opportunityId])
  @@index([initiativeId])
}

// Auth.js-compatible tables kept intact for future SSO and SCIM work.
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}

// ── Use Cases ─────────────────────────────────────────────────────────────────
// A structured, AI-generated solution spec linked to a validated Opportunity.

model UseCase {
  id                  String    @id @default(cuid())
  workspaceId         String
  opportunityId       String    @unique   // 1-to-1 with Opportunity
  title               String
  processDescription  String    @db.Text
  expectedOutcome     String    @db.Text
  solutionType        String    @default("automation") // "automation"|"assistant"|"analysis"|"generation"
  solutionDescription String?   @db.Text
  processSteps        Json?     // string[]
  kpis                Json      // [{ label, baseline, target, unit }]
  roiEstimated        Json      // { savings_hours_per_month, savings_euros_per_year, payback_months, assumptions }
  effortDays          Int       @default(0)
  effortBreakdown     Json?     // { design, development, testing, deployment }
  dataRequired        Json      // [{ source, type, available }]
  risks               Json      // [{ description, mitigation, level }]
  recommendedTools    Json?     // string[]
  nextSteps           Json?     // string[]
  priorityLevel       String    @default("P2")    // "P0" | "P1" | "P2"
  status              String    @default("backlog") // "backlog"|"analysis"|"active"|"deployed"|"paused"
  assignedTo          String?   // responsible business owner user id
  technicalOwner      String?   // DSI / IT manager user id
  consultantId        String?
  validatedBy         String?
  validatedAt         DateTime?
  deployedAt          DateTime?
  constraints         String?   @db.Text
  // Post-deployment real metrics
  realKpis            Json?     // [{ label, realValue }]
  realRoiAnalysis     String?   @db.Text   // Claude-generated impact analysis
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity Opportunity    @relation("OpportunityUseCase", fields: [opportunityId], references: [id], onDelete: Cascade)
  diagram     ProcessDiagram?

  @@index([workspaceId, status])
  @@index([workspaceId, priorityLevel])
}

// ── Process Diagrams ──────────────────────────────────────────────────────────

model ProcessDiagram {
  id               String    @id @default(cuid())
  useCaseId        String?   @unique
  processId        String?   @unique  // alternative entry point from Process
  xml              String    @db.Text
  svg              String?   @db.Text
  thumbnail        String?   @db.Text // base64 mini-SVG preview
  versionCount     Int       @default(1)
  validationStatus String    @default("draft") // draft|in-review|validated|rejected
  baMetadata       Json?     // {[elementId]: {duration?,actor?,tool?,painScore?,automatable?,kpi?}}
  lastAutoSave     DateTime?
  createdBy        String
  updatedBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  useCase     UseCase?               @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  process     Process?               @relation(fields: [processId], references: [id], onDelete: Cascade)
  versions    ProcessDiagramVersion[]
  comments    DiagramComment[]
  assignments DiagramTaskAssignment[]
}

model ProcessDiagramVersion {
  id            String   @id @default(cuid())
  diagramId     String
  versionNumber Int
  xml           String   @db.Text
  svg           String?  @db.Text
  changeSummary String?  @db.Text
  autoSaved     Boolean  @default(false)
  createdBy     String
  createdAt     DateTime @default(now())

  diagram ProcessDiagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [createdBy], references: [id])

  @@unique([diagramId, versionNumber])
  @@index([diagramId, createdAt])
}

model DiagramComment {
  id          String    @id @default(cuid())
  diagramId   String
  authorId    String
  elementId   String?   // BPMN element ID, null = general comment
  elementType String?   // task|gateway|event|pool|lane|sequence
  content     String    @db.Text
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  diagram ProcessDiagram         @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  author  User                   @relation("DiagramCommentAuthor", fields: [authorId], references: [id])
  replies DiagramCommentReply[]

  @@index([diagramId, elementId])
  @@index([diagramId, resolved])
}

model DiagramCommentReply {
  id        String   @id @default(cuid())
  commentId String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comment DiagramComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author  User           @relation("DiagramReplyAuthor", fields: [authorId], references: [id])

  @@index([commentId])
}

model DiagramTaskAssignment {
  id         String    @id @default(cuid())
  diagramId  String
  elementId  String    // BPMN task element ID
  assigneeId String
  assignedBy String
  role       String?   // analyst|reviewer|approver|observer
  dueDate    DateTime?
  status     String    @default("pending") // pending|in-progress|done
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  diagram  ProcessDiagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  assignee User           @relation("DiagramAssignee", fields: [assigneeId], references: [id])
  assigner User           @relation("DiagramAssigner", fields: [assignedBy], references: [id])

  @@unique([diagramId, elementId, assigneeId])
  @@index([diagramId, elementId])
  @@index([assigneeId])
}

// ── Email OTP Verification ────────────────────────────────────────────────────

model EmailVerification {
  id         String   @id @default(cuid())
  email      String
  code       String   // bcrypt-hashed 6-digit code
  expires_at DateTime
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([email])
}

// ── Process Steps ──────────────────────────────────────────────────────────────

model ProcessStep {
  id          String   @id @default(cuid())
  processId   String
  name        String
  description String?  @db.Text
  order       Int
  actor       String   @default("human") // human|system|automated
  tool        String?
  durationMin Int?
  isManual    Boolean  @default(true)
  painScore   Int?
  automatable Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId, order])
}

// ── Process KPIs ──────────────────────────────────────────────────────────────

model ProcessKPI {
  id            String  @id @default(cuid())
  processId     String
  name          String
  unit          String                    // "heures", "%", "€", "jours", "nombre"
  currentValue  Float?
  targetValue   Float?
  direction     String  @default("down") // "down" = réduire | "up" = augmenter
  measurement   String?
  sourceSystem  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

// ── Process Dependencies ───────────────────────────────────────────────────────

model ProcessDependency {
  id             String @id @default(cuid())
  sourceId       String  // processus source (dépend de target)
  targetId       String  // processus déclencheur (prérequis)
  dependencyType String  @default("upstream") // upstream|downstream|parallel
  description    String?
  createdAt      DateTime @default(now())

  source Process @relation("DependencySource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Process @relation("DependencyTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
}

// ── Process History ────────────────────────────────────────────────────────────

model ProcessHistory {
  id          String   @id @default(cuid())
  processId   String
  userId      String
  action      String   // created|updated|bpmn_generated|bpmn_validated|status_changed|kpi_added|dependency_added|maturity_updated
  description String?
  createdAt   DateTime @default(now())

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([processId, createdAt])
  @@index([userId])
}

// ── Technology ────────────────────────────────────────────────────────────────

model Technology {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  category        String    // os|database|runtime|framework|infra|security|cloud
  vendor          String?
  versionCurrent  String?
  lifecycleState  String    @default("adopt") // emerging|adopt|trial|hold|phaseout
  eolDate         DateTime?
  licenseType     String?
  annualCost      Float?
  riskLevel       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  applications AppTechnologyMap[]

  @@index([workspaceId])
  @@index([workspaceId, lifecycleState])
}

// ── Junction: Application <-> Capability ──────────────────────────────────────

model AppCapabilityMap {
  applicationId String
  capabilityId  String
  coverage      String @default("partial") // full|partial|planned

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  capability  Capability  @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([applicationId, capabilityId])
  @@index([capabilityId])
}

// ── Junction: Application <-> Technology ──────────────────────────────────────

model AppTechnologyMap {
  applicationId String
  technologyId  String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  technology  Technology  @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([applicationId, technologyId])
  @@index([technologyId])
}

// ── AI Readiness Assessment ───────────────────────────────────────────────────

model AIReadinessAssessment {
  id                   String   @id @default(cuid())
  workspaceId          String
  entityType           String
  entityId             String
  assessedAt           DateTime
  assessedBy           String
  dataQualityScore     Float
  integrationScore     Float
  complianceScore      Float
  automationPotential  Float
  operationalFitScore  Float
  overallScore         Float
  classification       String   // leader|advanced|developing|beginner
  breakdown            Json
  recommendations      Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([workspaceId])
}

// ── Architecture Decisions ────────────────────────────────────────────────────

model ArchitectureDecision {
  id                 String    @id @default(cuid())
  workspaceId        String
  title              String
  status             String    @default("proposed") // proposed|accepted|superseded|deprecated
  decisionDate       DateTime
  authorId           String
  context            String    @db.Text
  decision           String    @db.Text
  rationale          String    @db.Text
  consequences       String?   @db.Text
  alternatives       Json?
  impactedApps       Json?
  impactedProcesses  Json?
  expectedOutcome    String?   @db.Text
  observedOutcome    String?   @db.Text
  outcomeDate        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation("ArchDecisionAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status])
  @@index([authorId])
}

// ── Sprint 4 ──────────────────────────────────────────────────────────────────

// P24 — Executive Copilot
model CopilotConversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String?
  messages    Json     // [{role:"user"|"assistant", content:string, createdAt:string}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId])
}

// P25 — Scenario Engine
model Scenario {
  id                String   @id @default(cuid())
  workspaceId       String
  title             String
  description       String?  @db.Text
  status            String   @default("draft") // draft|active|archived
  items             Json?    // [{opportunityId?,title,investmentEuros,expectedGainEuros,timelineMonths,effort}]
  totalInvestment   Float?
  totalExpectedGain Float?
  roi               Float?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

// P28 — Notification Center
model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  type        String   // opportunity_assigned|usecase_validated|survey_published|adr_created|etc
  title       String
  body        String?  @db.Text
  link        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, read])
  @@index([workspaceId, createdAt])
}

// P33 — Webhooks
model Webhook {
  id          String   @id @default(cuid())
  workspaceId String
  url         String   @db.Text
  events      Json     // string[] of event types
  secret      String
  active      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([workspaceId, active])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  eventType   String
  payload     Json
  statusCode  Int?
  responseBody String? @db.Text
  success     Boolean  @default(false)
  duration    Int?     // ms
  createdAt   DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, success])
  @@index([webhookId, createdAt])
}

// ── Sprint 3 ──────────────────────────────────────────────────────────────────

// P19 — Ingestion pipeline
model IngestionJob {
  id                String   @id @default(cuid())
  workspaceId       String
  fileName          String
  fileType          String   // pdf|docx|xlsx|csv|txt
  fileSize          Int?
  status            String   @default("pending") // pending|processing|done|failed
  rawContent        String?  @db.LongText
  parsedData        Json?
  extractedEntities Json?
  targetEntityType  String?  // application|process|capability
  errorMessage      String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

// P20 — AI Relationship Suggester
model RelationshipSuggestion {
  id          String   @id @default(cuid())
  workspaceId String   @db.VarChar(30)  // CUID max 25 chars
  sourceType  String   @db.VarChar(50)  // entity type names are short
  sourceId    String   @db.VarChar(30)  // CUID max 25 chars
  targetType  String   @db.VarChar(50)  // entity type names are short
  targetId    String   @db.VarChar(30)  // CUID max 25 chars
  confidence  Float    @default(0)
  rationale   String   @db.Text
  status      String   @default("pending") // pending|accepted|rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // @@unique key size: (30+50+30+50+30) × 4 bytes (utf8mb4) = 760 bytes — well under 3072
  @@unique([workspaceId, sourceType, sourceId, targetType, targetId])
  @@index([workspaceId, status])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
}

// P21 — AI Data Quality Report
model DataQualityReport {
  id              String   @id @default(cuid())
  workspaceId     String
  entityType      String   // workspace|application|process|capability
  entityId        String?
  overallScore    Int      @default(0) // 0-100
  issues          Json?
  recommendations Json?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityType])
  @@index([workspaceId, generatedAt])
}

// P22 — Survey & Attestation engine
model Survey {
  id               String    @id @default(cuid())
  workspaceId      String
  title            String
  description      String?   @db.Text
  status           String    @default("draft") // draft|active|closed
  dueDate          DateTime?
  targetEntityType String?   // application|process|capability
  targetEntityId   String?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  questions  SurveyQuestion[]
  responses  SurveyResponse[]

  @@index([workspaceId, status])
}

model SurveyQuestion {
  id       String  @id @default(cuid())
  surveyId String
  order    Int     @default(0)
  type     String  @default("text") // text|rating|choice|yesno
  label    String  @db.Text
  options  Json?   // For choice type: array of strings
  required Boolean @default(false)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId, order])
}

model SurveyResponse {
  id           String   @id @default(cuid())
  surveyId     String
  respondentId String?
  answers      Json     // { questionId: answer } map
  submittedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([respondentId])
}

model Attestation {
  id           String    @id @default(cuid())
  workspaceId  String
  entityType   String    // application|process|capability
  entityId     String
  status       String    @default("pending") // pending|attested|expired
  attestedById String?
  attestedAt   DateTime?
  validUntil   DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, status])
}

// ── User Guide System ─────────────────────────────────────────────────────────

model UserGuideProgress {
  id               String    @id @default(cuid())
  userId           String    @unique
  toursCompleted   Json      // string[] — tour ids completed
  toursDismissed   Json      // string[] — tour ids dismissed
  checklistSteps   Json      // Record<string, string | null> — step_id → ISO timestamp or null
  helpEnabled      Boolean   @default(true)
  tooltipsEnabled  Boolean   @default(true)
  lastHelpOpenedAt DateTime?
  totalHelpViews   Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PageFirstVisit {
  id        String   @id @default(cuid())
  userId    String
  pagePath  String
  visitedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pagePath])
  @@index([userId])
}

// ── LLM Multi-Provider Router ─────────────────────────────────────────────────

model LLMCallLog {
  id           String   @id @default(cuid())
  workspaceId  String?
  task         String                        // task identifier (e.g. "opportunity_structure")
  provider     String                        // ollama|groq|claude
  model        String   @default("unknown")
  latencyMs    Int      @default(0)
  tokensUsed   Int?
  costCents    Int      @default(0)          // 0 for open source, estimated for Claude
  fallbackUsed Boolean  @default(false)
  fallbackTo   String?                       // next provider if this one failed
  success      Boolean
  error        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([provider, createdAt])
  @@index([task, success])
  @@index([createdAt])
}

model LLMConfig {
  id              String   @id @default(cuid())
  strategy        String   @default("auto")    // auto|ollama_only|groq_only|claude_only
  ollamaEnabled   Boolean  @default(true)
  groqEnabled     Boolean  @default(true)
  claudeEnabled   Boolean  @default(true)
  claudeForceTasks Json    @default("[]")       // string[] — always use Claude for these tasks
  logEnabled      Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

// ── Certification catalog (global, seeded once) ───────────────────────────────
model CertificationCatalog {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  shortName        String
  family           String   // qualite|securite|sectorielle|reglementaire|france|donnees
  description      String   @db.Text
  scope            String   @db.Text
  keyRequirements  Json     @default("[]")
  typicalProcesses Json     @default("[]")
  typicalDomains   Json     @default("[]")
  certifyingBody   String?
  validityYears    Int?
  auditFrequency   String?
  isMandatory      Boolean  @default(false)
  mandatoryFor     Json?
  riskIfMissing    String?  @db.Text
  officialUrl      String?
  costEstimate     String?
  sectors          Json?    // string[] — sector codes where this is relevant
  sizeMin          Json?    // string[] — minimum company sizes: tpe|pme|eti|ge
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  workspaceCertifications WorkspaceCertification[]

  @@index([family])
  @@index([isMandatory])
}

// ── Workspace certifications ──────────────────────────────────────────────────
// Tracks both obtained certifications and targets declared during onboarding.
model WorkspaceCertification {
  id             String    @id @default(cuid())
  workspaceId    String
  catalogId      String
  // obtained | in_progress | planned | not_applicable | expired
  status         String
  obtainedDate   DateTime?
  expiryDate     DateTime?
  nextAuditDate  DateTime?
  certifyingBody String?
  certificateRef String?
  documentUrl    String?
  scopeNotes     String?   @db.Text
  ownerId        String?
  notes          String?   @db.Text
  // onboarding_current | onboarding_target | manual | auto_sector
  source         String    @default("manual")
  alert90Sent    Boolean   @default(false)
  alert30Sent    Boolean   @default(false)
  alert0Sent     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  catalog   CertificationCatalog @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  owner     User?                @relation("CertificationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  links     CertificationLink[]

  @@unique([workspaceId, catalogId])
  @@index([workspaceId, status])
  @@index([workspaceId, expiryDate])
  @@index([ownerId])
}

// ── Certification ↔ entity links ──────────────────────────────────────────────
model CertificationLink {
  id                       String   @id @default(cuid())
  workspaceCertificationId String
  entityType               String   // process|application|capability|domain
  entityId                 String
  coverage                 String   @default("full") // full|partial
  notes                    String?
  createdAt                DateTime @default(now())

  certification WorkspaceCertification @relation(fields: [workspaceCertificationId], references: [id], onDelete: Cascade)

  @@unique([workspaceCertificationId, entityType, entityId])
  @@index([entityType, entityId])
}

// ── Aria — Assistante IA contextuelle ────────────────────────────────────────

model AriaSession {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  pagePath    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages AriaMessage[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId, createdAt])
}

model AriaMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // 'user' | 'aria'
  content   String   @db.Text
  pagePath  String
  actions   Json?
  createdAt DateTime @default(now())

  session AriaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AriaDismissal {
  id           String   @id @default(cuid())
  userId       String
  suggestionId String
  pagePath     String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, suggestionId])
  @@index([userId])
}
