  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --experimental-strip-types tests/run-all.ts",
    "test:scoring": "node --experimental-strip-types tests/scoring.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:seed": "node --env-file=.env.example --env-file-if-exists=.env prisma/seed.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node --env-file=.env.example --env-file-if-exists=.env prisma/seed.js"
  },
  "dependencies": {
